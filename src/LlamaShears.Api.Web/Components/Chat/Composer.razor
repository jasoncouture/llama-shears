@using System.Collections.Immutable
@using LlamaShears.Api.Web.Services
@using LlamaShears.Core.Abstractions.Content
@using Microsoft.AspNetCore.Components.Forms
@implements IDisposable
@inject IChatSession Session
@inject IJSRuntime JS

<form class="composer" @onsubmit="SubmitAsync" @onsubmit:preventDefault>
    @if (_pending.Count > 0)
    {
        <div class="composer-pending">
            @for (var i = 0; i < _pending.Count; i++)
            {
                var index = i;
                var attachment = _pending[index];
                <div class="composer-pending-item">
                    @if (attachment.Kind == AttachmentKind.Image)
                    {
                        <img src="@($"data:{attachment.MimeType};base64,{attachment.Base64Data}")" alt="pending" />
                    }
                    <button type="button"
                            class="composer-pending-remove"
                            title="Remove"
                            aria-label="Remove attachment"
                            @onclick="() => RemovePending(index)">×</button>
                </div>
            }
        </div>
    }
    <div class="composer-row">
        <label class="composer-attach" title="Attach an image" aria-label="Attach an image">
            <Icon Name="paperclip" />
            <InputFile OnChange="OnFilePickedAsync" accept="image/*" disabled="@NoAgent" />
        </label>
        <textarea
            @bind="_draft"
            @bind:event="oninput"
            placeholder="@Placeholder"
            rows="1"
            disabled="@NoAgent"
            data-composer-submit
            data-composer-paste-id="@_pasteId"></textarea>
        <button type="submit" disabled="@CannotSend">Send</button>
    </div>
    <small class="composer-hint">Enter to send · Shift+Enter for newline · paste or attach an image · <code>/clear</code> · <code>/archive</code> · <code>/compact</code></small>
</form>

@code {
    private const long MaxAttachmentBytes = 10 * 1024 * 1024;

    private string _draft = string.Empty;
    private readonly List<Attachment> _pending = [];
    private readonly string _pasteId = Guid.NewGuid().ToString("N");
    private DotNetObjectReference<Composer>? _selfRef;
    private bool _registered;

    private bool NoAgent => Session.SelectedAgentId is null;

    private bool CannotSend => NoAgent || (string.IsNullOrWhiteSpace(_draft) && _pending.Count == 0);

    private string Placeholder => NoAgent
        ? "Pick an agent above, then type your message..."
        : "Type a message...";

    protected override void OnInitialized()
    {
        Session.Changed += HandleChanged;
        _selfRef = DotNetObjectReference.Create(this);
    }

    protected override async Task OnAfterRenderAsync(bool firstRender)
    {
        if (!_registered && _selfRef is not null)
        {
            await JS.InvokeVoidAsync("composerPaste.register", _pasteId, _selfRef).ConfigureAwait(false);
            _registered = true;
        }
    }

    private void HandleChanged() => _ = InvokeAsync(StateHasChanged);

    [JSInvokable]
    public Task OnPasteAsync(string mimeType, string base64Data)
    {
        if (string.IsNullOrEmpty(base64Data) || string.IsNullOrEmpty(mimeType))
        {
            return Task.CompletedTask;
        }
        _pending.Add(new Attachment(AttachmentKind.Image, mimeType, base64Data));
        return InvokeAsync(StateHasChanged);
    }

    private async Task OnFilePickedAsync(InputFileChangeEventArgs e)
    {
        var file = e.File;
        if (file is null)
        {
            return;
        }
        if (!file.ContentType.StartsWith("image/", StringComparison.OrdinalIgnoreCase))
        {
            return;
        }
        if (file.Size > MaxAttachmentBytes)
        {
            return;
        }
        await using var stream = file.OpenReadStream(MaxAttachmentBytes);
        using var memory = new MemoryStream();
        await stream.CopyToAsync(memory);
        var base64 = Convert.ToBase64String(memory.ToArray());
        _pending.Add(new Attachment(AttachmentKind.Image, file.ContentType, base64));
        StateHasChanged();
    }

    private void RemovePending(int index)
    {
        if (index >= 0 && index < _pending.Count)
        {
            _pending.RemoveAt(index);
        }
    }

    private async Task SubmitAsync()
    {
        if (CannotSend)
        {
            return;
        }
        // SendAsync requires non-whitespace content even when only an
        // image is attached; pad with a single space if the textarea
        // is empty so the channel message has a body to ship.
        var content = string.IsNullOrWhiteSpace(_draft) ? " " : _draft;
        var attachments = _pending.ToImmutableArray();
        _draft = string.Empty;
        _pending.Clear();
        await Session.SendAsync(content, attachments, CancellationToken.None);
    }

    public void Dispose()
    {
        Session.Changed -= HandleChanged;
        if (_registered && _selfRef is not null)
        {
            try
            {
                _ = JS.InvokeVoidAsync("composerPaste.unregister", _pasteId);
            }
            catch
            {
                // Disposal during circuit teardown — JS interop may not
                // be reachable. Nothing to clean up that the browser
                // tab close won't handle.
            }
        }
        _selfRef?.Dispose();
    }
}
