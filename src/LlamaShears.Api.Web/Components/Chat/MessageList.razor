@using LlamaShears.Api.Web.Services
@implements IDisposable
@inject ChatSession Session

<section class="messages" data-auto-scroll data-agent="@(Session.SelectedAgentId ?? string.Empty)">
    @if (Session.SelectedAgentId is null)
    {
        <p class="messages-empty">Pick an agent to start a conversation.</p>
    }
    else if (Session.Bubbles.Count == 0)
    {
        <p class="messages-empty">No messages yet. Send something below.</p>
    }
    else
    {
        ChatBubbleKind? hiddenStreamingKind = null;
        foreach (var bubble in Session.Bubbles)
        {
            var hideAsThought = bubble.Kind == ChatBubbleKind.Thought && !Session.ShowThoughts;
            var hideAsStreaming = bubble.IsStreaming && !Session.ShowStreaming;
            if (hideAsThought || hideAsStreaming)
            {
                if (bubble.IsStreaming)
                {
                    hiddenStreamingKind = bubble.Kind;
                }
                continue;
            }
            <ChatBubbleView Bubble="@bubble" />
        }
        if (hiddenStreamingKind is { } kind)
        {
            var modifier = kind == ChatBubbleKind.Thought ? "thinking" : "responding";
            var label = kind == ChatBubbleKind.Thought ? "thinking" : "typing";
            <div class="typing-indicator typing-indicator-@modifier" role="status">
                <div class="typing-indicator-dots">
                    <span></span><span></span><span></span>
                </div>
                <small class="typing-indicator-label">@label</small>
            </div>
        }
    }
</section>

@code {
    protected override void OnInitialized()
    {
        Session.Changed += HandleChanged;
    }

    private void HandleChanged()
    {
        _ = InvokeAsync(StateHasChanged);
    }

    public void Dispose()
    {
        Session.Changed -= HandleChanged;
    }
}
