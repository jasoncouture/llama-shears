@using LlamaShears.Api.Web.Services
@implements IDisposable
@inject IChatSession Session

<section class="messages" data-auto-scroll data-agent="@(Session.SelectedAgentId ?? string.Empty)">
    @if (Session.SelectedAgentId is null)
    {
        <p class="messages-empty">Pick an agent to start a conversation.</p>
    }
    else if (Session.Bubbles.Count == 0)
    {
        <p class="messages-empty">No messages yet. Send something below.</p>
    }
    else
    {
        ChatBubbleKind? hiddenIndicatorKind = null;
        var hasVisibleBusy = false;
        foreach (var bubble in Session.Bubbles)
        {
            var hideAsThought = bubble.Kind == ChatBubbleKind.Thought && !Session.ShowThoughts;
            var hideAsTool = (bubble.Kind == ChatBubbleKind.ToolInFlight || bubble.Kind == ChatBubbleKind.ToolResult) && !Session.ShowTools;
            // ToolInFlight bubbles are governed by the tool toggle; the
            // streaming toggle only applies to thought/assistant streams.
            var hideAsStreaming = bubble.IsStreaming
                && !Session.ShowStreaming
                && bubble.Kind != ChatBubbleKind.ToolInFlight;
            if (hideAsThought || hideAsTool || hideAsStreaming)
            {
                if (bubble.IsStreaming)
                {
                    hiddenIndicatorKind = bubble.Kind;
                }
                continue;
            }
            if (bubble.IsStreaming)
            {
                hasVisibleBusy = true;
            }
            <ChatBubbleView Bubble="@bubble" AgentName="@Session.SelectedAgentId" />
        }
        if (hiddenIndicatorKind is { } kind && !hasVisibleBusy)
        {
            var (modifier, label) = kind switch
            {
                ChatBubbleKind.Thought => ("thinking", "thinking"),
                ChatBubbleKind.ToolInFlight => ("tooling", "running tools"),
                _ => ("responding", "typing"),
            };
            <div class="typing-indicator typing-indicator-@modifier" role="status">
                <div class="typing-indicator-dots">
                    <span></span><span></span><span></span>
                </div>
                <small class="typing-indicator-label">@label</small>
            </div>
        }
    }
</section>

@code {
    protected override void OnInitialized()
    {
        Session.Changed += HandleChanged;
    }

    private void HandleChanged()
    {
        _ = InvokeAsync(StateHasChanged);
    }

    public void Dispose()
    {
        Session.Changed -= HandleChanged;
    }
}
