@using LlamaShears.Api.Web.Services
@implements IDisposable
@inject IAgentDirectory Directory
@inject IChatSession Session
@inject NavigationManager Nav
@inject IJSRuntime JS

<div class="chat-header">
    <select id="agent-select" value="@Session.SelectedAgentId" @onchange="OnSelectionChangedAsync">
        @if (Session.SelectedAgentId is null)
        {
            <option value="">— select agent —</option>
        }
        @foreach (var id in _agentIds)
        {
            <option value="@id">@id</option>
        }
    </select>
    @if (_agentIds.Count == 0)
    {
        <span class="chat-header-empty">No agents loaded yet.</span>
    }
    <div class="chat-header-actions">
        <button type="button" class="chat-header-button" title="Refresh" aria-label="Refresh agents" @onclick="Refresh">
            <Icon Name="arrow-clockwise" />
        </button>
        <span class="chat-header-sep" aria-hidden="true"></span>
        <button type="button"
                class="chat-header-button chat-header-toggle @(Session.ShowThoughts ? "is-on" : null)"
                title="@(Session.ShowThoughts ? "Hide thinking" : "Show thinking")"
                aria-label="Toggle thinking visibility"
                aria-pressed="@(Session.ShowThoughts ? "true" : "false")"
                @onclick="ToggleThoughts">
            <Icon Name="lightbulb-fill" />
        </button>
        <button type="button"
                class="chat-header-button chat-header-toggle @(Session.ShowStreaming ? "is-on" : null)"
                title="@(Session.ShowStreaming ? "Hide streaming output" : "Show streaming output")"
                aria-label="Toggle streaming output"
                aria-pressed="@(Session.ShowStreaming ? "true" : "false")"
                @onclick="ToggleStreaming">
            <Icon Name="broadcast" />
        </button>
        <button type="button"
                class="chat-header-button chat-header-toggle @(Session.ShowTools ? "is-on" : null)"
                title="@(Session.ShowTools ? "Hide tool activity" : "Show tool activity")"
                aria-label="Toggle tool activity"
                aria-pressed="@(Session.ShowTools ? "true" : "false")"
                @onclick="ToggleTools">
            <Icon Name="tools" />
        </button>
    </div>
</div>

@code {
    private IReadOnlyList<string> _agentIds = [];
    private string? _loadedPrefsAgentId;

    protected override void OnInitialized()
    {
        Session.Changed += HandleChanged;
        Refresh();
    }

    protected override async Task OnAfterRenderAsync(bool firstRender)
    {
        var current = Session.SelectedAgentId;
        if (current is null || string.Equals(current, _loadedPrefsAgentId, StringComparison.Ordinal))
        {
            return;
        }
        _loadedPrefsAgentId = current;
        var thoughts = await ReadBoolAsync(ThoughtsKey(current)).ConfigureAwait(false);
        var streaming = await ReadBoolAsync(StreamingKey(current)).ConfigureAwait(false);
        var tools = await ReadBoolAsync(ToolsKey(current)).ConfigureAwait(false);
        if (thoughts is bool t)
        {
            Session.ShowThoughts = t;
        }
        if (streaming is bool s)
        {
            Session.ShowStreaming = s;
        }
        if (tools is bool to)
        {
            Session.ShowTools = to;
        }
    }

    private void HandleChanged() => _ = InvokeAsync(StateHasChanged);

    private void Refresh()
    {
        _agentIds = Directory.ListAgentIds();
    }

    private async Task ToggleThoughts()
    {
        Session.ShowThoughts = !Session.ShowThoughts;
        if (Session.SelectedAgentId is { } id)
        {
            await WriteBoolAsync(ThoughtsKey(id), Session.ShowThoughts).ConfigureAwait(false);
        }
    }

    private async Task ToggleStreaming()
    {
        Session.ShowStreaming = !Session.ShowStreaming;
        if (Session.SelectedAgentId is { } id)
        {
            await WriteBoolAsync(StreamingKey(id), Session.ShowStreaming).ConfigureAwait(false);
        }
    }

    private async Task ToggleTools()
    {
        Session.ShowTools = !Session.ShowTools;
        if (Session.SelectedAgentId is { } id)
        {
            await WriteBoolAsync(ToolsKey(id), Session.ShowTools).ConfigureAwait(false);
        }
    }

    private async Task OnSelectionChangedAsync(ChangeEventArgs e)
    {
        var id = e.Value as string;
        var normalized = string.IsNullOrWhiteSpace(id) ? null : id;
        await Session.SelectAgentAsync(normalized, CancellationToken.None);
        Nav.NavigateTo(normalized is null ? "/chat" : $"/chat/{Uri.EscapeDataString(normalized)}", replace: true);
    }

    private async ValueTask<bool?> ReadBoolAsync(string key)
    {
        var raw = await JS.InvokeAsync<string?>("localStorage.getItem", key).ConfigureAwait(false);
        return bool.TryParse(raw, out var v) ? v : null;
    }

    private ValueTask WriteBoolAsync(string key, bool value)
        => JS.InvokeVoidAsync("localStorage.setItem", key, value ? "true" : "false");

    private static string ThoughtsKey(string agentId) => $"llamashears:agent:{agentId}:showThoughts";

    private static string StreamingKey(string agentId) => $"llamashears:agent:{agentId}:showStreaming";

    private static string ToolsKey(string agentId) => $"llamashears:agent:{agentId}:showTools";

    public void Dispose()
    {
        Session.Changed -= HandleChanged;
    }
}
