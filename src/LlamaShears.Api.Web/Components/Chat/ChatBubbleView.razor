@using LlamaShears.Api.Web.Services

@if (Bubble.Kind == ChatBubbleKind.ToolInFlight)
{
    <article class="bubble bubble-tool-inflight bubble-pulse">
        <header class="bubble-header">
            <span class="bubble-kind">running tools</span>
            <time datetime="@Bubble.At.ToString("O")" title="@FullTimestamp">@Bubble.At.ToLocalTime().ToString("HH:mm:ss")</time>
            <span class="bubble-streaming">…</span>
        </header>
        <ul class="bubble-tool-list">
            @foreach (var tool in Bubble.InFlightTools ?? [])
            {
                <li><code>@FormatToolName(tool.Source, tool.Name)</code></li>
            }
        </ul>
    </article>
}
else if (Bubble.Kind == ChatBubbleKind.ToolResult)
{
    <article class="bubble bubble-tool-result @(Bubble.IsError ? "bubble-tool-error" : null)">
        <header class="bubble-header">
            <span class="bubble-kind">tool result</span>
            <code class="bubble-tool-name">@FormatToolName(Bubble.CompletedCall!.Source, Bubble.CompletedCall!.Name)</code>
            <time datetime="@Bubble.At.ToString("O")" title="@FullTimestamp">@Bubble.At.ToLocalTime().ToString("HH:mm:ss")</time>
            @if (Bubble.IsError)
            {
                <span class="bubble-tool-error-label">error</span>
            }
        </header>
        @if (HasArguments)
        {
            <details class="bubble-tool-args" open>
                <summary>arguments</summary>
                <pre class="bubble-tool-args-body">@Bubble.CompletedCall!.ArgumentsJson</pre>
            </details>
        }
        <details class="bubble-tool-body">
            <summary>result</summary>
            <pre class="bubble-content">@Bubble.Content</pre>
        </details>
    </article>
}
else
{
    <article class="bubble bubble-@KindClass @(Bubble.IsStreaming ? "bubble-pulse" : null)">
        <header class="bubble-header">
            @if (Bubble.Kind != ChatBubbleKind.User)
            {
                <span class="bubble-kind">@KindLabel</span>
            }
            <time datetime="@Bubble.At.ToString("O")" title="@FullTimestamp">@Bubble.At.ToLocalTime().ToString("HH:mm:ss")</time>
            @if (Bubble.IsStreaming)
            {
                <span class="bubble-streaming">…</span>
            }
        </header>
        <pre class="bubble-content">@Bubble.Content</pre>
    </article>
}

@code {
    [Parameter, EditorRequired]
    public ChatBubble Bubble { get; set; } = default!;

    [Parameter]
    public string? AgentName { get; set; }

    private string KindClass => Bubble.Kind switch
    {
        ChatBubbleKind.User => "user",
        ChatBubbleKind.Assistant => "assistant",
        ChatBubbleKind.Thought => "thought",
        _ => "unknown",
    };

    private string KindLabel => Bubble.Kind == ChatBubbleKind.Assistant && !string.IsNullOrWhiteSpace(AgentName)
        ? AgentName
        : Bubble.Kind.ToString();

    private string FullTimestamp => Bubble.At.ToLocalTime().ToString("F", System.Globalization.CultureInfo.CurrentCulture);

    // The Ollama provider flattens (source, name) to source__name on the
    // wire; that's a provider-specific transport detail and shouldn't
    // leak into the UI. Render the pair with a dot separator instead.
    private static string FormatToolName(string source, string name) => $"{source}.{name}";

    private bool HasArguments
    {
        get
        {
            var args = Bubble.CompletedCall?.ArgumentsJson;
            return !string.IsNullOrWhiteSpace(args) && args != "{}";
        }
    }
}
