@using LlamaShears.Api.Web.Services
@inject IAgentDirectory Directory
@inject ChatSession Session

<div class="agent-picker">
    <select id="agent-select" value="@Session.SelectedAgentId" @onchange="OnSelectionChangedAsync">
        <option value="">— select agent —</option>
        @foreach (var id in _agentIds)
        {
            <option value="@id">@id</option>
        }
    </select>
    @if (_agentIds.Count == 0)
    {
        <span class="agent-picker-empty">No agents loaded yet.</span>
    }
    <button type="button" class="agent-picker-refresh" title="Refresh" aria-label="Refresh agents" @onclick="Refresh">
        <svg class="icon" viewBox="0 0 16 16" aria-hidden="true">
            <path fill-rule="evenodd" d="M8 3a5 5 0 1 0 4.546 2.914.5.5 0 0 1 .908-.417A6 6 0 1 1 8 2z"/>
            <path d="M8 4.466V.534a.25.25 0 0 1 .41-.192l2.36 1.966c.12.1.12.284 0 .384L8.41 4.658A.25.25 0 0 1 8 4.466"/>
        </svg>
    </button>
</div>

@code {
    private IReadOnlyList<string> _agentIds = [];

    protected override void OnInitialized()
    {
        Refresh();
    }

    private void Refresh()
    {
        _agentIds = Directory.ListAgentIds();
    }

    private async Task OnSelectionChangedAsync(ChangeEventArgs e)
    {
        var id = e.Value as string;
        await Session.SelectAgentAsync(string.IsNullOrWhiteSpace(id) ? null : id, CancellationToken.None);
    }
}
