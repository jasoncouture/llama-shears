@using LlamaShears.Api.Web.Services
@inject IAgentDirectory Directory
@inject ChatSession Session

<div class="agent-picker">
    <label for="agent-select">Agent</label>
    <select id="agent-select" value="@Session.SelectedAgentId" @onchange="OnSelectionChanged">
        <option value="">— select agent —</option>
        @foreach (var id in _agentIds)
        {
            <option value="@id">@id</option>
        }
    </select>
    <button type="button" @onclick="Refresh">Refresh</button>
    @if (_agentIds.Count == 0)
    {
        <span class="agent-picker-empty">No agents loaded yet.</span>
    }
</div>

@code {
    private IReadOnlyList<string> _agentIds = [];

    protected override void OnInitialized()
    {
        Refresh();
    }

    private void Refresh()
    {
        _agentIds = Directory.ListAgentIds();
    }

    private void OnSelectionChanged(ChangeEventArgs e)
    {
        var id = e.Value as string;
        Session.SelectAgent(string.IsNullOrWhiteSpace(id) ? null : id);
    }
}
