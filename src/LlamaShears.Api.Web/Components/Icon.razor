@using LlamaShears.Api.Web.Services
@inject IIconProvider Icons

<svg class="@CssClass" width="@Width" height="@Height" viewBox="0 0 16 16" aria-hidden="true" @attributes="AdditionalAttributes">
    @((MarkupString)_inner)
</svg>

@code {
    [Parameter, EditorRequired]
    public string Name { get; set; } = default!;

    [Parameter]
    public int Width { get; set; } = 16;

    [Parameter]
    public int Height { get; set; } = 16;

    [Parameter]
    public string? Class { get; set; }

    [Parameter(CaptureUnmatchedValues = true)]
    public IReadOnlyDictionary<string, object>? AdditionalAttributes { get; set; }

    private string _inner = string.Empty;

    private string CssClass => string.IsNullOrEmpty(Class) ? "icon" : $"icon {Class}";

    protected override void OnParametersSet()
    {
        _inner = Icons.GetInnerSvg(Name);
    }
}
