@page "/chat/{AgentId?}"
@using LlamaShears.Core
@inject IChatSession Session
@inject IAgentDirectory Directory
@inject IAgentInstanceRepository Repository
@inject NavigationManager Nav

<PageTitle>LlamaShears</PageTitle>

<div class="chat">
    <section class="conversation">
        <ChatHeader />
        <MessageList />
    </section>
    <Composer />
</div>

@code {
    [Parameter]
    public string? AgentId { get; set; }

    protected override async Task OnInitializedAsync()
    {
        if (string.IsNullOrWhiteSpace(AgentId))
        {
            return;
        }
        if (!Directory.ListAgentIds().Contains(AgentId)
            || !Repository.TryGetDefaultSession(AgentId, out var sessionId)
            || !Repository.TryGetAgent(sessionId, out var handle))
        {
            Nav.NavigateTo("/chat");
            return;
        }
        await Session.SelectSessionAsync(handle.SessionPath.Current, CancellationToken.None);
    }
}
