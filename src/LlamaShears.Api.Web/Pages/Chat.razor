@page "/chat/{AgentId?}"
@using LlamaShears.Api.Web.Services
@inject IChatSession Session
@inject IAgentDirectory Directory
@inject NavigationManager Nav

<PageTitle>LlamaShears</PageTitle>

<div class="chat">
    <section class="conversation">
        <ChatHeader />
        <MessageList />
    </section>
    <Composer />
</div>

@code {
    [Parameter]
    public string? AgentId { get; set; }

    protected override async Task OnInitializedAsync()
    {
        if (string.IsNullOrWhiteSpace(AgentId))
        {
            return;
        }
        if (Directory.ListAgentIds().Contains(AgentId))
        {
            await Session.SelectAgentAsync(AgentId, CancellationToken.None);
        }
        else
        {
            Nav.NavigateTo("/chat", replace: true);
        }
    }
}
