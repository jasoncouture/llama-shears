@page "/agents"
@using LlamaShears.Core
@using LlamaShears.Core.Abstractions.Agent
@using LlamaShears.Core.Abstractions.Agent.Sessions
@inject IAgentConfigProvider Configs
@inject IAgentInstanceRepository Repository

<PageTitle>Agents — LlamaShears</PageTitle>

<div class="agent-list">
    <header class="agent-list-header">
        <h2>Agents</h2>
    </header>
    @if (_ids.Count == 0)
    {
        <p class="agent-list-empty">No agent config files found on disk.</p>
    }
    else
    {
        <ul class="agent-list-items">
            @foreach (var id in _ids)
            {
                <li>
                    <div class="agent-list-row">
                        <a class="agent-list-link" href="/agents/@Uri.EscapeDataString(id)/edit">@id</a>
                        @{
                            var sessions = SessionsFor(id);
                            var defaultSession = DefaultSession(sessions);
                        }
                        @if (sessions.Count == 0)
                        {
                            <span class="agent-list-sessions agent-list-sessions-empty">no live sessions</span>
                        }
                        else
                        {
                            <ul class="agent-list-sessions">
                                @foreach (var handle in sessions)
                                {
                                    var session = handle.SessionPath.Current;
                                    var isDefault = ReferenceEquals(handle, defaultSession);
                                    <li class="agent-list-session @(isDefault ? "agent-list-session-default" : null)">
                                        <span>@session.Name</span>
                                    </li>
                                }
                            </ul>
                        }
                    </div>
                </li>
            }
        </ul>
    }
</div>

@code {
    private IReadOnlyList<string> _ids = [];

    protected override void OnInitialized()
    {
        _ids = Configs.ListAgentIds();
    }

    private IReadOnlyList<AgentHandle> SessionsFor(string agentId)
    {
        return [.. Repository.GetAllAgents()
            .Where(h => string.Equals(h.SessionPath.Current.AgentId, agentId, StringComparison.OrdinalIgnoreCase))
            .OrderByDescending(h => h.SessionPath.IsRootSession)
            .ThenBy(h => h.SessionPath.Current.Name, StringComparer.OrdinalIgnoreCase)];
    }

    private static AgentHandle? DefaultSession(IReadOnlyList<AgentHandle> sessions)
    {
        foreach (var handle in sessions)
        {
            if (handle.SessionPath.IsRootSession && handle.SessionPath.Current.IsDefault)
            {
                return handle;
            }
        }
        return null;
    }
}
