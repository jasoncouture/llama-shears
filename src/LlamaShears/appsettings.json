{
  "Logging": {
    "LogLevel": {
      "Default": "Information",
      "Microsoft.AspNetCore": "Warning",
      "Microsoft.Extensions.Http": "Warning",
      "System.Net.Http.": "Warning"
    },
    "Console": {
      "FormatterName": "simple",
      "FormatterOptions": {
        "SingleLine": true,
        "TimestampFormat": "'\u001b[90m['yyyy-MM-ddTHH:mm:ssK']\u001b[0m '",
        "ColorBehavior": "Enabled"
      }
    }
  },
  "AllowedHosts": "*",
  "Providers": {
    "Ollama": {
      "BaseUri": "http://crapple.alertr.info:11434/"
    }
  },
  "Memory": {
    "DefaultEmbeddingModel": "OLLAMA/embeddinggemma:latest",
    "DefaultEmbeddingQueryPrefix": "task: search result | query: ",
    "DefaultEmbeddingDocumentPrefix": "title: none | text: ",
    "Indexer": {
      "Enabled": true,
      "Interval": "00:30:00",
      "ForceOnStartup": true
    }
  }
}
