{
  "Logging": {
    "LogLevel": {
      "Default": "Debug",
      "Microsoft.AspNetCore": "Warning",
      "Microsoft.Extensions.Http": "Information",
      "System.Net.Http": "Information",
      "System.Net.Http.HttpClient.ModelContextProtocolToolDiscovery": "Warning",
      "ModelContextProtocol.Server.McpServer": "Warning"
    },
    "Console": {
      "FormatterName": "simple",
      "FormatterOptions": {
        "SingleLine": true,
        "TimestampFormat": "'\u001b[90m['yyyy-MM-ddTHH:mm:ssK']\u001b[0m '",
        "ColorBehavior": "Enabled"
      }
    }
  },
  "AllowedHosts": "*",
  "Providers": {
    "Ollama": {
      "BaseUri": "http://crapple.alertr.info:11434/"
    },
    "OpenAI": {
      "BaseUri": "http://crapple.alertr.info:8080/"
    },
    "Onnx": {
      "Embeddings": {
        "Models": {
          "all-minilm-l6-v2-qint8-avx512-vnni": {
            "DisplayName": "all-MiniLM-L6-v2 (qint8, AVX-512+VNNI)",
            "Description": "Sentence-Transformers all-MiniLM-L6-v2, int8 quantized, AVX-512+VNNI optimized.",
            "MaxSequenceLength": 256
          }
        }
      }
    }
  },
  "Memory": {
    "DefaultEmbeddingModel": "OLLAMA/embeddinggemma:latest",
    "DefaultEmbeddingQueryPrefix": "task: search result | query: ",
    "DefaultEmbeddingDocumentPrefix": "title: none | text: ",
    "Indexer": {
      "Enabled": true,
      "Interval": "00:30:00",
      "ForceOnStartup": true
    }
  }
}
