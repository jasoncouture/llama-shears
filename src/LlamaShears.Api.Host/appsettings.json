{
  "Logging": {
    "LogLevel": {
      "Default": "Information",
      "Microsoft.AspNetCore": "Warning",
      "LlamaShears.Provider.Ollama": "Debug"
    },
    "Console": {
      "FormatterName": "simple",
      "FormatterOptions": {
        "SingleLine": true,
        "TimestampFormat": "'\u001b[90m['yyyy-MM-ddTHH:mm:ssK']\u001b[0m '",
        "ColorBehavior": "Enabled"
      }
    }
  },
  "AllowedHosts": "*",
  "Providers": {
    "Ollama": {
      "BaseUri": "http://nas.alertr.info:11434/"
    }
  },
  "Data": {
    "ConnectionString": "Data Source=llamashears.db"
  }
}
