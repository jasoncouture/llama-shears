root = true

[*.cs]
# AGENTS.md policy: do not use primary constructors on regular classes
# or structs (records may). Disable the analyzer that suggests them.
csharp_style_prefer_primary_constructors = false
dotnet_diagnostic.IDE0290.severity = none

# CA1859 ("Use concrete types when possible for improved performance")
# is a premature-optimisation prompt that pushes consumers off the
# interface they're meant to depend on, and pushes tests off the
# interface they're meant to assert against (see ADR-0023). Disabled
# repo-wide.
dotnet_diagnostic.CA1859.severity = none

# CA1822 ("Mark members as static") creates refactor churn that costs
# more than the trivial dispatch savings it chases (see ADR-0025).
# Disabled repo-wide; methods are static when the author wrote them
# static, not because the analyzer asked.
dotnet_diagnostic.CA1822.severity = none

# Collections must use the collection expression form (`[]`) wherever it
# applies. Promoted to error per-diagnostic so the build (not just the IDE)
# fails on `new[] { ... }`, `Type<...>.Empty`, `Array.Empty<T>()`,
# `ImmutableX.Create(...)`, builder, and fluent forms.
#
# Per-ID lines are required: the inline `:error` on the option key drives
# IDE severity but EnforceCodeStyleInBuild only honors per-diagnostic
# severity for the IDE03xx family. The option key still has to set the
# value (`when_types_loosely_match`) — that's what makes the rule fire at
# all; the per-ID lines are what make it fail the build.
dotnet_style_prefer_collection_expression = when_types_loosely_match:error
dotnet_diagnostic.IDE0300.severity = error
dotnet_diagnostic.IDE0301.severity = error
dotnet_diagnostic.IDE0302.severity = error
dotnet_diagnostic.IDE0303.severity = error
dotnet_diagnostic.IDE0304.severity = error
dotnet_diagnostic.IDE0305.severity = error

# IDE0001 ("Name can be simplified") promoted to error so `System.Guid`,
# `System.Collections.Generic.Dictionary<,>`, etc. fail the build instead
# of riding as IDE-only hints. Forces the matching using/global-using or
# the unqualified name to be used.
dotnet_style_qualification_for_field = false:error
dotnet_diagnostic.IDE0001.severity = error

# Consts are PascalCase, no leading underscore. Listed *before* the
# private-fields rule so it wins on `private const`; without this the
# field-kind rule below would demand the `_camelCase` prefix on consts.
dotnet_naming_rule.consts_pascal_case.severity = warning
dotnet_naming_rule.consts_pascal_case.symbols = consts
dotnet_naming_rule.consts_pascal_case.style = pascal_case

dotnet_naming_symbols.consts.applicable_kinds = field
dotnet_naming_symbols.consts.applicable_accessibilities = *
dotnet_naming_symbols.consts.required_modifiers = const

dotnet_naming_style.pascal_case.capitalization = pascal_case

# Private fields use _camelCase. Without an explicit rule, the IDE's
# "encapsulate field" / "introduce field" autofixes default to plain
# camelCase, which doesn't match the codebase. Applies to instance and
# static private fields alike — this project does not use the s_ prefix.
dotnet_naming_rule.private_fields_underscore_camel_case.severity = warning
dotnet_naming_rule.private_fields_underscore_camel_case.symbols = private_fields
dotnet_naming_rule.private_fields_underscore_camel_case.style = underscore_camel_case

dotnet_naming_symbols.private_fields.applicable_kinds = field
dotnet_naming_symbols.private_fields.applicable_accessibilities = private

dotnet_naming_style.underscore_camel_case.required_prefix = _
dotnet_naming_style.underscore_camel_case.capitalization = camel_case
