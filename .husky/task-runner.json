{
   "$schema": "https://alirezanet.github.io/Husky.Net/schema.json",
   "tasks": [
      {
         "name": "dotnet-build-on-source-change",
         "group": "pre-commit",
         "include": [
            "**/*.cs",
            "**/*.razor",
            "**/*.csproj",
            "**/*.sln",
            "**/*.slnx",
            "**/*.props"
         ],
         "command": "bash",
         "args": [ "-c", "dotnet clean && dotnet build", "_", "${staged}" ]
      }
   ]
}
